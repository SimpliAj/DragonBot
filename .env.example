# Dragon Bot Configuration
# Copy this file to .env and fill in your actual values

# Discord Bot Token
DISCORD_TOKEN=your_discord_bot_token_here

# Developer User ID (for dev commands)
DEV_USER_ID=your_discord_user_id

# Error Webhook URL (for error logging)
ERROR_WEBHOOK_URL=your_webhook_url_here

# Top.gg Webhook Authentication Token (if using Top.gg integration)
TOPGG_WEBHOOK_AUTH=your_topgg_webhook_auth_token_here

# Optional: Additional configuration can be added here
# DATABASE_PATH=dragon_bot.db
# LOG_LEVEL=INFO
